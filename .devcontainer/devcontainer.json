{
  "name": "synthetic-family",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/common-utils:2": {},
    // Required for `gh codespace ssh` / `gh codespace cp`: the base image
    // ships no SSH server (unlike GitHub's default Codespaces image), and
    // without one every CLI route into the codespace fails — including the
    // README's step for reading .devcontainer/admin.json.
    "ghcr.io/devcontainers/features/sshd:1": {}
  },

  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb"
  },

  "containerEnv": {
    // Bind-mount source for compose; resolved relative to the compose project
    // dir (.semiont/compose/), NOT the repo root.
    "SEMIONT_CONFIG": "../semiontconfig/anthropic.toml",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://jaeger:4318",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },

  "postCreateCommand": ".devcontainer/post-create.sh",
  "postStartCommand": ".devcontainer/post-start.sh",

  "forwardPorts": [3000, 4000, 16686, 7474, 9090, 9091, 9092],
  "portsAttributes": {
    "3000": { "label": "Semiont Browser", "onAutoForward": "notify" },
    "4000": { "label": "Backend API", "onAutoForward": "notify" },
    "16686": { "label": "Jaeger UI", "onAutoForward": "notify" },
    "7474": { "label": "Neo4j Browser", "onAutoForward": "silent" },
    "9090": { "label": "Worker health", "onAutoForward": "silent" },
    "9091": { "label": "Smelter health", "onAutoForward": "silent" },
    "9092": { "label": "Weaver health", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
