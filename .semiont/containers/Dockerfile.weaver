FROM node:24-alpine

RUN apk add --no-cache curl
ARG NPM_REGISTRY=https://registry.npmjs.org
# neo4j-driver is a lazy peer of @semiont/graph (loaded at connect time,
# per graph sink) — the weaver is the one make-meaning entry point that
# actually dials the graph, so it must be installed here explicitly, the
# same way Dockerfile.backend does.
RUN npm config set registry $NPM_REGISTRY && \
    npm install -g @semiont/make-meaning neo4j-driver && \
    npm cache clean --force

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 semiont

WORKDIR /kb
RUN chown semiont:nodejs /kb

USER semiont

ARG SEMIONT_CONFIG=.semiont/containers/semiontconfig/ollama-gemma.toml
COPY --chown=semiont:nodejs ${SEMIONT_CONFIG} /home/semiont/.semiontconfig

ENV NODE_ENV=production
EXPOSE 9092

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:9092/health || exit 1

CMD ["node", "/usr/local/lib/node_modules/@semiont/make-meaning/dist/weaver-main.js"]
