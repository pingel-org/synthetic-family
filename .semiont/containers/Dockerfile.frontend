FROM node:20-alpine

ARG NPM_REGISTRY=https://registry.npmjs.org
RUN npm config set registry $NPM_REGISTRY && \
    npm install -g @semiont/cli && npm cache clean --force

WORKDIR /app

RUN cat <<'EOF' > /root/.semiontconfig
[user]
name = "semiont"
email = ""

[defaults]
environment = "local"

[environments.local.frontend]
platform = "posix"
port = 3000
publicURL = "http://localhost:3000"
EOF

EXPOSE 3000

CMD semiont provision --verbose --service frontend && \
    semiont start --verbose -s frontend && \
    tail -f /root/.local/state/semiont/frontend/app.log
